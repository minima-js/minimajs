{
  "name": "@minimajs/cli",
  "version": "0.1.0",
  "description": "CLI for running, watching, and compiling MinimaJS TypeScript projects",
  "type": "module",
  "license": "MIT",
  "homepage": "https://minimajs.com",
  "repository": {
    "type": "github",
    "directory": "packages/cli",
    "url": "https://github.com/minima-js/minimajs"
  },
  "main": "./lib/index.js",
  "bin": {
    "minimajs": "./bin/cli.js"
  },
  "exports": {
    ".": "./lib/index.js"
  },
  "scripts": {
    "build": "bun bundler.ts",
    "dev": "bun bundler.ts --watch",
    "clean": "rimraf -g '*.tsbuildinfo' lib"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "yocto-spinner": "^1.1.0",
    "@types/node": "^22.0.0",
    "chalk": "^5.4.1",
    "citty": "^0.2.1",
    "dotenv": "^17.0.0",
    "dotenv-expand": "^12.0.0",
    "pretty-bytes": "^6.1.1",
    "pretty-ms": "^9.2.0",
    "rimraf": "^6.0.0"
  },
  "files": [
    "bin",
    "lib"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "minimajs",
    "cli",
    "typescript",
    "esbuild",
    "build",
    "watch"
  ],
  "author": "Adil <adil.sudo@gmail.com>"
}
