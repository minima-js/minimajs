{
  "name": "@minimajs/aws-s3",
  "version": "0.0.2",
  "type": "module",
  "description": "AWS S3 storage driver for @minimajs/disk—use web-native File APIs instead of AWS SDK",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js"
  },
  "scripts": {
    "dev": "tsc -w --preserveWatchOutput",
    "build": "tsc -p ./tsconfig.build.json",
    "test": "bun test --timeout=2000",
    "coverage": "bun test --coverage --timeout=2000",
    "clean": "rimraf -g '*.tsbuildinfo' lib"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.992.0",
    "@aws-sdk/lib-storage": "^3.992.0"
  },
  "peerDependencies": {
    "@minimajs/disk": ">=0.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@minimajs/disk": "workspace:*",
    "@types/node": "^25.0.3",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "minimajs",
    "disk",
    "storage",
    "s3",
    "aws",
    "file-upload",
    "cloud-storage"
  ],
  "author": "Adil <adil.sudo@gmail.com>",
  "files": [
    "lib"
  ],
  "license": "MIT",
  "homepage": "https://minimajs.com/packages/disk/aws-s3",
  "repository": {
    "type": "github",
    "directory": "packages/aws-s3",
    "url": "https://github.com/minima-js/minimajs"
  }
}
