{
  "name": "@minimajs/azure-blob",
  "version": "0.0.3",
  "type": "module",
  "description": "Azure Blob Storage driver for @minimajs/disk — use web-native File APIs instead of Azure SDK",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js"
  },
  "scripts": {
    "dev": "tsc -w --preserveWatchOutput",
    "build": "tsc -p ./tsconfig.build.json",
    "test": "bun test --timeout=2000",
    "coverage": "bun test --coverage --timeout=2000",
    "clean": "rimraf -g '*.tsbuildinfo' lib"
  },
  "devDependencies": {
    "@minimajs/disk": "workspace:*",
    "@types/node": "^25.0.3",
    "@jest/globals": "^30.2.0"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.29.1"
  },
  "peerDependencies": {
    "@minimajs/disk": ">=0.0.1"
  },
  "keywords": [
    "minimajs",
    "disk",
    "storage",
    "azure",
    "azure-blob",
    "file-upload",
    "cloud-storage"
  ],
  "author": "Adil <adil.sudo@gmail.com>",
  "license": "MIT",
  "homepage": "https://minimajs.com/packages/disk/azure-blob",
  "repository": {
    "type": "github",
    "directory": "packages/azure-blob",
    "url": "https://github.com/minima-js/minimajs"
  },
  "files": [
    "lib"
  ]
}